{
  "name": "decision-tree-selector",
  "version": "0.1.0",
  "description": "A lightweight React library for building and managing complex selection UIs that behave like a decision tree.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.5",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GitaiQAQ/decision-tree-selector.git"
  },
  "bugs": {
    "url": "https://github.com/GitaiQAQ/decision-tree-selector/issues"
  },
  "homepage": "https://github.com/GitaiQAQ/decision-tree-selector#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && npm run build:lib && npm run build:demo",
    "build:demo": "vite build",
    "build:lib": "tsup src/index.ts --format esm,cjs --dts --clean",
    "build-storybook": "storybook build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "storybook:phase1": "storybook dev -p 6006 --host 127.0.0.1",
    "test": "vitest run",
    "test:phase1": "vitest run src/selector/testing/switchable-phase1.test.ts",
    "test:phase2": "vitest run src/selector/testing/phase2-gate.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.5.2",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.0.2",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.8",
    "playwright": "^1.54.2",
    "storybook": "^10.2.19",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
